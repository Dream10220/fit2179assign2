          "type": "nominal"
        },
        "y": {
          "field": "g",
          "type": "nominal"
        },
        "text": {
          "field": "n",
          "type": "quantitative"
        },
        "color": {
          "condition": {
            "test": "datum.colShare>0.55",
            "value": "#F2F4EF"
          },
