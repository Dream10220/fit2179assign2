            "titleFontWeight": 700,
            "titleColor": "#5C6B62"
          }
        },
        "color": {
          "field": "colShare",
          "type": "quantitative",
          "scale": {
            "scheme": "greens"
          },
          "title": "% of the state's most threatened group",
          "legend": {
            "format": "%",
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 220,
            "gradientThickness": 14,
            "titleFontSize": 12,
            "labelFontSize": 11,
